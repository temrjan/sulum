generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // extensions = [vector] -- using Qdrant instead
}

model User {
  id                 String              @id @default(uuid())
  telegramId         BigInt              @unique
  firstName          String?
  lastName           String?
  username           String?
  language           String              @default("ru")
  isAdmin            Boolean             @default(false)
  dailyMsgCount      Int                 @default(0)
  lastMsgDate        DateTime?
  gdprConsent        Boolean             @default(false)
  gdprConsentDate    DateTime?
  termsAccepted      Boolean             @default(false)
  termsAcceptedDate  DateTime?
  dataRetention      Boolean             @default(true)
  analyticsConsent   Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lastActiveAt       DateTime            @default(now())
  completedContent   CompletedContent[]
  contentReviews     ContentReview[]
  conversations      Conversation[]
  dataExportRequests DataExportRequest[]
  favorites          Favorite[]
  searchQueries      SearchQuery[]
  subscription       Subscription?
  events             UserEvent[]
  profile            UserProfile?
  progress           UserProgress[]
  payments           Payment[]

  @@index([telegramId])
  @@index([language])
  @@index([lastActiveAt])
}

model UserProfile {
  id                   String    @id @default(uuid())
  userId               String    @unique
  isPregnant           Boolean   @default(false)
  pregnancyStartDate   DateTime?
  dueDate              DateTime?
  currentWeek          Int?
  interests            String[]
  notificationsEnabled Boolean   @default(true)
  reminderTime         String?
  timezone             String    @default("Asia/Tashkent")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  children             Child[]
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Child {
  id              String           @id @default(uuid())
  profileId       String
  name            String
  birthDate       DateTime
  gender          Gender?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  profile         UserProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  growthRecords   GrowthRecord[]
  introducedFoods IntroducedFood[]
  milestones      Milestone[]
  reminders       Reminder[]

  @@index([profileId])
  @@index([birthDate])
  @@index([isActive])
}

model Subscription {
  id              String             @id @default(uuid())
  userId          String             @unique
  tier            SubscriptionTier
  status          SubscriptionStatus
  isRecurring     Boolean            @default(true)
  billingInterval BillingInterval    @default(MONTHLY)
  startDate       DateTime           @default(now())
  endDate         DateTime?
  trialEndDate    DateTime?
  lastPaymentDate DateTime?
  nextBillingDate DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  willCancelAt    DateTime?
  discountPercent Int                @default(0)
  promoCode       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  payments        Payment[]
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([nextBillingDate])
}

model Payment {
  id             String          @id @default(uuid())
  userId         String?
  subscriptionId String?
  invoiceId      String?         @unique
  externalUuid   String?
  checkoutUrl    String?
  amount         Decimal         @db.Decimal(10, 2)
  currency       String          @default("UZS")
  provider       PaymentProvider
  transactionId  String?
  status         PaymentStatus
  billingPeriod  BillingInterval?
  metadata       Json?
  createdAt      DateTime        @default(now())
  completedAt    DateTime?
  user           User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription?   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([provider])
  @@index([invoiceId])
}
model PromoCode {
  id              String    @id @default(uuid())
  code            String    @unique
  discountPercent Int?
  discountAmount  Decimal?  @db.Decimal(10, 2)
  maxUses         Int?
  usedCount       Int       @default(0)
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  isActive        Boolean   @default(true)
  referredBy      String?
  createdAt       DateTime  @default(now())

  @@index([code])
  @@index([isActive])
  @@index([validUntil])
}

model Content {
  id                   String               @id @default(uuid())
  defaultLanguage      String               @default("ru")
  type                 ContentType
  mediaUrl             String?
  thumbnailUrl         String?
  duration             Int?
  categoryId           String
  tags                 String[]
  accessTier           SubscriptionTier     @default(FREE)
  relevantForPregnancy Boolean              @default(false)
  minWeek              Int?
  maxWeek              Int?
  relevantForChild     Boolean              @default(false)
  minAgeMonths         Int?
  maxAgeMonths         Int?
  medicallyReviewed    Boolean              @default(false)
  reviewedBy           String?
  reviewedAt           DateTime?
  requiresDisclaimer   Boolean              @default(true)
  averageRating        Decimal?             @db.Decimal(3, 2)
  ratingCount          Int                  @default(0)
  viewCount            Int                  @default(0)
  completionCount      Int                  @default(0)
  shareCount           Int                  @default(0)
  favoriteCount        Int                  @default(0)
  version              Int                  @default(1)
  lastEditedBy         String?
  lastEditedAt         DateTime?
  status               ContentStatus        @default(DRAFT)
  submittedForReview   Boolean              @default(false)
  submittedAt          DateTime?
  submittedBy          String?
  reviewNotes          String?
  published            Boolean              @default(false)
  publishedAt          DateTime?
  publishedBy          String?
  scheduledPublishAt   DateTime?
  authorId             String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  completions          CompletedContent[]
  author               Admin?               @relation(fields: [authorId], references: [id])
  category             Category             @relation(fields: [categoryId], references: [id])
  reviewer             MedicalReviewer?     @relation(fields: [reviewedBy], references: [id])
  analytics            ContentAnalytics?
  embedding            ContentEmbedding?
  reviews              ContentReview[]
  translations         ContentTranslation[]
  versionHistory       ContentVersion[]
  favorites            Favorite[]

  @@index([categoryId])
  @@index([published])
  @@index([accessTier])
  @@index([status])
  @@index([type])
}

model ContentTranslation {
  id              String   @id @default(uuid())
  contentId       String
  language        String
  title           String
  description     String?
  body            String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  content         Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, language])
  @@index([language])
}

model ContentEmbedding {
  id        String   @id @default(uuid())
  contentId String   @unique
  embedding String?
  createdAt DateTime @default(now())
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model ContentReview {
  id           String   @id @default(uuid())
  contentId    String
  userId       String
  rating       Int
  comment      String?
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  content      Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([contentId])
  @@index([rating])
}

model ContentVersion {
  id          String   @id @default(uuid())
  contentId   String
  version     Int
  title       String
  description String?
  body        String?
  editedBy    String
  editedAt    DateTime @default(now())
  changeNotes String?
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([editedAt])
}

model ContentAnalytics {
  id             String    @id @default(uuid())
  contentId      String    @unique
  totalViews     Int       @default(0)
  uniqueViews    Int       @default(0)
  avgTimeSpent   Int       @default(0)
  completionRate Decimal   @db.Decimal(5, 2)
  views30d       Int       @default(0)
  completions30d Int       @default(0)
  lastViewedAt   DateTime?
  updatedAt      DateTime  @updatedAt
  content        Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([totalViews])
  @@index([views30d])
}

model Category {
  id           String                @id @default(uuid())
  slug         String                @unique
  icon         String?
  order        Int                   @default(0)
  parentId     String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  parent       Category?             @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]            @relation("CategoryHierarchy")
  translations CategoryTranslation[]
  contents     Content[]

  @@index([slug])
  @@index([parentId])
  @@index([order])
}

model CategoryTranslation {
  id          String   @id @default(uuid())
  categoryId  String
  language    String
  name        String
  description String?
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, language])
  @@index([language])
}

model MedicalReviewer {
  id              String    @id @default(uuid())
  name            String
  credentials     String
  licenseNumber   String?
  email           String    @unique
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  reviewedContent Content[]

  @@index([email])
  @@index([isActive])
}

model Milestone {
  id          String        @id @default(uuid())
  childId     String
  type        MilestoneType
  title       String
  description String?
  achievedAt  DateTime
  photos      String[]
  video       String?
  createdAt   DateTime      @default(now())
  child       Child         @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([achievedAt])
  @@index([type])
}

model GrowthRecord {
  id                String   @id @default(uuid())
  childId           String
  date              DateTime @default(now())
  weight            Decimal? @db.Decimal(5, 2)
  height            Decimal? @db.Decimal(5, 2)
  headCircumference Decimal? @db.Decimal(5, 2)
  notes             String?
  createdAt         DateTime @default(now())
  child             Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([date])
}

model IntroducedFood {
  id           String        @id @default(uuid())
  childId      String
  foodName     String
  category     FoodCategory
  introducedAt DateTime
  reaction     FoodReaction?
  notes        String?
  createdAt    DateTime      @default(now())
  child        Child         @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([category])
  @@index([introducedAt])
}

model UserProgress {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @default(now())
  weight    Decimal? @db.Decimal(5, 2)
  notes     String?
  mood      Int?
  metrics   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model CompletedContent {
  id          String   @id @default(uuid())
  userId      String
  contentId   String
  completedAt DateTime @default(now())
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@index([contentId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@index([contentId])
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId])
  @@index([updatedAt])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model SearchQuery {
  id           String   @id @default(uuid())
  userId       String?
  query        String
  resultsCount Int
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model Reminder {
  id             String               @id @default(uuid())
  userId         String
  childId        String?
  type           ReminderType
  title          String
  description    String?
  isRecurring    Boolean              @default(false)
  recurrenceRule String?
  scheduledFor   DateTime
  nextOccurrence DateTime?
  sent           Boolean              @default(false)
  sentAt         DateTime?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  child          Child?               @relation(fields: [childId], references: [id], onDelete: Cascade)
  occurrences    ReminderOccurrence[]

  @@index([userId])
  @@index([childId])
  @@index([nextOccurrence])
  @@index([isActive])
  @@index([type])
}

model ReminderOccurrence {
  id           String   @id @default(uuid())
  reminderId   String
  scheduledFor DateTime
  sentAt       DateTime
  reminder     Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId])
  @@index([sentAt])
}

model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  role      AdminRole @default(CONTENT_MANAGER)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  contents  Content[]

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model UserEvent {
  id         String    @id @default(uuid())
  userId     String
  eventType  EventType
  eventName  String
  metadata   Json?
  contentId  String?
  categoryId String?
  platform   String?
  appVersion String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@index([contentId])
}

model DataExportRequest {
  id          String       @id @default(uuid())
  userId      String
  status      ExportStatus @default(PENDING)
  requestedAt DateTime     @default(now())
  completedAt DateTime?
  downloadUrl String?
  expiresAt   DateTime?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELLED
  EXPIRED
  PAYMENT_FAILED
}

enum BillingInterval {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum PaymentProvider {
  MULTICARD
  CLICK
  PAYME
  STRIPE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ContentType {
  ARTICLE
  VIDEO
  AUDIO
  CHECKLIST
  RECIPE
  INFOGRAPHIC
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum MilestoneType {
  MOTOR
  SPEECH
  SOCIAL
  COGNITIVE
  FEEDING
  CUSTOM
}

enum FoodCategory {
  VEGETABLE
  FRUIT
  GRAIN
  MEAT
  FISH
  DAIRY
  EGG
  NUTS
  OTHER
}

enum FoodReaction {
  POSITIVE
  NEUTRAL
  NEGATIVE
  ALLERGIC
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ReminderType {
  FEEDING
  DOCTOR_VISIT
  VACCINATION
  MEDICATION
  MILESTONE
  CUSTOM
}

enum AdminRole {
  SUPER_ADMIN
  CONTENT_MANAGER
  MODERATOR
}

enum EventType {
  CONTENT_VIEWED
  CONTENT_COMPLETED
  SEARCH_PERFORMED
  AI_CHAT_STARTED
  SUBSCRIPTION_PURCHASED
  PROFILE_UPDATED
  REMINDER_SET
  MILESTONE_ADDED
  FOOD_INTRODUCED
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  EXPIRED
}
